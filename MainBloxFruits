-- ===== FARM SETTINGS TAB =====
Tabs.Farm:AddToggle({
    Title = "Auto Farm Enemy",
    Description = "Tu dong farm mob gan nhat",
    Default = false,
    Callback = function(val)
        autoFarm = val
        if autoFarm then
            task.spawn(function()
                while autoFarm do
                    char = player.Character
                    hrp = char and char:FindFirstChild("HumanoidRootPart")
                    for _, v in pairs(workspace:GetDescendants()) do
                        if not autoFarm then break end
                        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") then
                            local hum = v:FindFirstChild("Humanoid")
                            if hum and hum.Health > 0 and v ~= char then
                                if hrp then
                                    hrp.CFrame = CFrame.new(v.HumanoidRootPart.Position + Vector3.new(0, 3, 0))
                                end
                                task.wait(0.1)
                            end
                        end
                    end
                    task.wait(0.1)
                end
            end)
        end
    end
})

Tabs.Farm:AddToggle({
    Title = "Auto Quest",
    Description = "Tu dong nhan quest phu hop level",
    Default = false,
    Callback = function(val)
        autoQuest = val
        task.spawn(function()
            while autoQuest do
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("ProximityPrompt") and v.Parent.Name:find("Quest") then
                        fireproximityprompt(v)
                        task.wait(0.5)
